# ===========================================================
# EASY DUNYA — variables d'environnement
# Copiez ce fichier vers .env puis remplissez les valeurs.
# ===========================================================

# URL publique de l'API Supabase
# - Supabase cloud  : https://<projet>.supabase.co
# - Supabase local  : http://localhost:8000  (Kong gateway via docker-compose)
VITE_SUPABASE_URL=http://localhost:8000

# Clé publique anon (safe en frontend, protégée par RLS)
# Pour Supabase local (docker-compose fourni), ce JWT est signé avec JWT_SECRET="super-secret-jwt-token-with-at-least-32-characters-long"
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTc5OTUzNTYwMH0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE

# Clé VAPID publique pour Web Push (générer avec `npx web-push generate-vapid-keys`)
VITE_VAPID_PUBLIC_KEY=

# Locale par défaut au premier chargement
VITE_DEFAULT_LOCALE=fr
